            const tl = gsap.timeline();
            
            tl.to('.hero-bg-img', { scale: 1, duration: 4, ease: 'power2.out' })
              .to('.hero-subtitle', { y: 0, opacity: 1, duration: 1.5, ease: 'power4.out' }, '-=3.5')
              .to('.hero-title', { y: 0, opacity: 1, duration: 2, ease: 'expo.out' }, '-=2.8')
              .to('.scroll-indicator', { opacity: 1, y: -5, duration: 1, ease: 'power2.out' }, '-=1.2');

            gsap.to('.hero-bg-container', { scrollTrigger: { trigger: 'body', start: 'top top', end: 'bottom top', scrub: true }, yPercent: 20, ease: 'none' });
            gsap.to('.info-item', { scrollTrigger: { trigger: '.info-item', start: 'top 90%' }, opacity: 1, y: 0, duration: 1, stagger: 0.15, ease: 'power3.out' });
            gsap.to('.section-title', { scrollTrigger: { trigger: '.section-title', start: 'top 95%' }, y: 0, duration: 1.2, ease: 'power4.out', stagger: 0.2 });
            gsap.to('.section-subtitle', { scrollTrigger: { trigger: '.section-title', start: 'top 95%' }, opacity: 1, duration: 1.5, delay: 0.3, ease: 'power2.out' });
            
            gsap.fromTo('.project-card', 
                { opacity: 0, y: 80, scale: 0.95 }, 
                { scrollTrigger: { trigger: '#repositorio', start: 'top 75%' }, opacity: 1, y: 0, scale: 1, duration: 1.2, stagger: 0.1, ease: 'power3.out' }
            );

            const filterBtns = document.querySelectorAll('.filter-btn');
            const cards = document.querySelectorAll('.project-card');

            if(filterBtns[0]) filterBtns[0].classList.add('border-upla-accent', 'text-white', 'bg-upla-primary/20');

            filterBtns.forEach(btn => {
                btn.addEventListener('click', () => {
                    filterBtns.forEach(b => b.classList.remove('border-upla-accent', 'text-white', 'bg-upla-primary/20'));
                    btn.classList.add('border-upla-accent', 'text-white', 'bg-upla-primary/20');
                    const filterValue = btn.getAttribute('data-filter');

                    gsap.to(cards, {
                        opacity: 0, scale: 0.9, y: 20, duration: 0.3, stagger: 0.04,
                        onComplete: () => {
                            cards.forEach(card => {
                                const cardUnidad = card.getAttribute('data-unidad');
                                if (filterValue === 'all' || cardUnidad === filterValue) {
                                    (card as HTMLElement).style.display = 'flex';
                                    gsap.to(card, { opacity: 1, scale: 1, y: 0, duration: 0.4, ease: 'power3.out' });
                                } else {
                                    (card as HTMLElement).style.display = 'none';
                                }
                            });
                            ScrollTrigger.refresh();
                        }
                    });
                });
            });

            // Lógica para abrir el Modal de Login
            const btnLogin = document.getElementById('btn-abrir-login');
            if (btnLogin) {
                btnLogin.addEventListener('click', (e) => {
                    e.preventDefault();
                    window.dispatchEvent(new Event('open-login-modal'));
                });
            }
        });
    </script>
</Layout>